        customers = conn.execute('''
            SELECT * FROM customers 
            WHERE name LIKE ? OR client_code LIKE ? OR email LIKE ?
            ORDER BY name
        ''', (f'%{search}%', f'%{search}%', f'%{search}%')).fetchall()
    else:
        customers = conn.execute('SELECT * FROM customers ORDER BY name').fetchall()
